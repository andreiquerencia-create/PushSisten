# =============================================================================
# PushSisten - Environment Variables Example
# =============================================================================
# Copie este arquivo para `.env` e preencha com os valores reais.
# NUNCA commit o arquivo `.env` real — ele já está no .gitignore.
# =============================================================================

# Banco de dados PostgreSQL (Prisma)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# NextAuth — segredo usado para assinar tokens JWT
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# IA (LLM — OpenAI ou qualquer provedor compatível com OpenAI API)
LLM_API_BASE_URL="https://api.openai.com"
LLM_API_KEY="sk-your-openai-key-here"
LLM_MODEL="gpt-4o-mini"

# AWS / S3 — bucket usado para armazenar arquivos do app
# Remova AWS_PROFILE se estiver rodando localmente sem profile nomeado
AWS_PROFILE="your_aws_profile_name"
AWS_REGION="us-west-2"
AWS_BUCKET_NAME="your_bucket_name"
AWS_FOLDER_PREFIX="your_folder_prefix"

# Worker de backup — segredo compartilhado entre o app e o worker
BACKUP_WORKER_SECRET="your_backup_worker_secret"

# IDs de empresas protegidas contra exclusão (separados por vírgula)
PROTECTED_COMPANY_IDS="company_id_1,company_id_2"

# Billing / Mercado Pago
BILLING_PROVIDER="mock"
BILLING_GRACE_DAYS="15"
MP_ACCESS_TOKEN="your_mercadopago_access_token"
MP_PUBLIC_KEY="your_mercadopago_public_key"
MP_SANDBOX="true"
MP_WEBHOOK_SECRET="your_mercadopago_webhook_secret"
