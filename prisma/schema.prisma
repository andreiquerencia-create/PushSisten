// ============================================================
// PUSH SCORE™ — FUNDAÇÃO DE DADOS (PRIORIDADE 3.2)
// Apenas estrutura de persistência/configuração/histórico.
// NÃO contém engine de cálculo, scheduler, dashboard ou IA.
// ============================================================

// Snapshot histórico do Push Score de uma empresa em uma data.
// Guarda: resultado final, classificação textual, cada sub-score
// (componentes) e os insumos brutos (rawMetrics) que geraram o score,
// permitindo auditoria futura ("por que o score era X no dia Y?").
model PushScoreSnapshot {
  id                String   @id @default(cuid())
  companyId         String
  date              DateTime // dia de referência do snapshot (BRT)

  // status estrutural: EM_FORMACAO (dados insuficientes) | ATIVO
  status            String   @default("EM_FORMACAO")

  // resultado final 0-100 (nullable enquanto EM_FORMACAO / antes do cálculo)
  score             Float?
  // classificação textual: SAUDAVEL | ESTAVEL | ATENCAO | RISCO | CRITICO
  classification    String?

  // componentes (sub-scores 0-100 por dimensão) — nullable até serem calculados
  rentabilityScore  Float?   // Rentabilidade (peso 25%)
  liquidityScore    Float?   // Liquidez (peso 20%)
  inventoryScore    Float?   // Saúde do Estoque = 50% Giro + 50% Capital Parado (peso 15%)
  defaultScore      Float?   // Inadimplência (peso 15%)
  customerBaseScore Float?   // Base de Clientes (peso 15%)
  growthScore       Float?   // Crescimento (peso 10%)

  // insumos brutos que geraram o score (auditoria) — ex:
  // { margemLiquida, cashMonths, capitalParadoPct, giroEstoque,
  //   inadimplenciaPct, crescimentoPct, clientesAtivosPct, ... }
  rawMetrics        Json?

  // pesos efetivamente aplicados neste snapshot (auditoria de repesagem
  // dinâmica — ex.: empresa sem crediário redistribui o peso da inadimplência)
  appliedWeights    Json?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company           Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, date])           // 1 snapshot por empresa por dia (idempotência)
  @@index([companyId])                   // histórico por empresa
  @@index([companyId, date])             // consultas por data / tendências
  @@index([companyId, status])           // filtrar EM_FORMACAO vs ATIVO
  @@map("push_score_snapshots")
}

// Configuração de pesos do Push Score.
// companyId nulo = configuração GLOBAL (benchmark padrão da plataforma).
// companyId preenchido = override por empresa (ajuste sem alterar código).
model PushScoreConfig {
  id                String   @id @default(cuid())
  companyId         String?  // null = config global; preenchido = override da empresa

  // pesos por dimensão (0-100, devem somar 100) — defaults V1 oficiais
  rentabilityWeight Float    @default(25)
  liquidityWeight   Float    @default(20)
  inventoryWeight   Float    @default(15)
  defaultWeight     Float    @default(15)
  customerWeight    Float    @default(15)
  growthWeight      Float    @default(10)

  active            Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company           Company? @relation(fields: [companyId], references: [id])

  @@unique([companyId])     // no máximo 1 config por empresa (e 1 global com companyId null)
  @@index([active])
  @@map("push_score_configs")
}

// Insights Engine — insights acionáveis gerados deterministicamente
// Persistidos por empresa+dia para auditoria e consumo futuro (IA Gerente, dashboard, automações)
model Insight {
  id              String   @id @default(cuid())
  companyId       String
  date            DateTime // dia BRT do insight (normalizado 00:00)
  type            String   // ESTOQUE | CLIENTE | FINANCEIRO | CREDIARIO
  code            String   // código único do insight (ex: ESTOQUE_PARADO, CLIENTE_SUMIDO)
  severity        String   // ALTO | MEDIO | BAIXO
  message         String   // mensagem em PT-BR acionável
  relatedMetrics  Json?    // dados de suporte (IDs, valores, thresholds)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, date, code], name: "unique_insight_per_company_day_code")
  @@index([companyId])
  @@index([companyId, date])
  @@index([companyId, type])
  @@index([severity])
  @@map("insights")
}

// Automation Engine (PRIORIDADE 6) — fila oficial de ações automatizáveis
// Gerada a partir da IA Gerente 2.0 (que consome Insights Engine + Push Score).
// NÃO executa envios reais nesta fase: gera ação + registra log + deixa pronto para execução futura.
// Idempotente por companyId+date+type+reference. Multiempresa. Auditável.
model AutomationAction {
  id           String    @id @default(cuid())
  companyId    String
  date         DateTime  // dia BRT (normalizado 00:00) para idempotência
  type         String    // ALERTA_INTERNO | CLIENTE_INATIVO | COBRANCA_CREDIARIO | PRODUTO_PARADO | ESTOQUE_BAIXO | RELATORIO_GERENCIAL
  status       String    @default("PENDENTE") // PENDENTE | EXECUTADO | IGNORADO | ERRO
  severity     String    @default("BAIXO")    // ALTO | MEDIO | BAIXO
  reference    String    // referência única dentro do dia+tipo (ex: código do insight)
  title        String    // título curto da ação (PT-BR)
  description  String    // descrição/contexto da ação (PT-BR)
  channel      String    @default("INTERNO")  // INTERNO | WHATSAPP | EMAIL (futuro) — apenas rótulo, sem envio real
  payload      Json?     // dados estruturados (template de mensagem, alvos, métricas)
  insightCode  String?   // código do insight relacionado (rastreabilidade)
  pushScoreImpact Int    @default(0) // impacto estimado no Push Score (0-3)
  executedAt   DateTime? // quando foi marcada como executada/ignorada
  error        String?   // mensagem de erro se status=ERRO
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company      Company   @relation(fields: [companyId], references: [id])

  @@unique([companyId, date, type, reference], name: "unique_action_per_company_day_type_ref")
  @@index([companyId])
  @@index([companyId, date])
  @@index([companyId, status])
  @@index([type])
  @@map("automation_actions")
}
// ============================================================================
// BILLING / ASSINATURAS (P8.4) — billing-engine é a fonte única.
// plan-engine.ts continua sendo a fonte da verdade de PLANO/PREÇO/LIMITE.
// Gateway (Mercado Pago hoje, Stripe no futuro) = APENAS processador de cobrança.
// BillingPayment é ESPELHO HISTÓRICO — nenhuma regra de plano/acesso/status
// depende diretamente dele. A verdade vem de: Gateway → Webhook → Billing Engine.
// ============================================================================

// Cliente de cobrança — desacopla a Company do gateway de pagamento.
// 1:1 com Company. Permite trocar/adicionar provider sem migrar a Company.
model BillingCustomer {
  id                 String   @id @default(cuid())
  companyId          String   @unique
  provider           String   // mercadopago | stripe
  externalCustomerId String?  // id do pagador/cliente no gateway (payer id MP / customer Stripe)
  email              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company       Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscriptions BillingSubscription[]

  @@index([provider])
  @@map("billing_customers")
}

// Assinatura vinculada ao gateway. Carrega os dados que ANTES estavam na Company.
model BillingSubscription {
  id                     String    @id @default(cuid())
  billingCustomerId      String
  provider               String    // mercadopago | stripe
  externalSubscriptionId String?   // ex-mpPreapprovalId (id da assinatura no gateway)
  plan                   String    // referência ao plan-engine (fonte da verdade)
  priceAmount            Float     @default(0) // espelho do plan-engine no momento da venda
  currency               String    @default("BRL")
  cycle                  String    @default("monthly")
  status                 String    @default("pending") // pending | authorized | active | paused | cancelled
  nextBillingDate        DateTime?
  lastPaymentDate        DateTime?
  lastPaymentStatus      String?   // approved | rejected | refunded | pending
  paymentMethodBrand     String?   // só exibição (nunca o cartão)
  paymentMethodLast4     String?   // só exibição
  startedAt              DateTime?
  canceledAt             DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  billingCustomer BillingCustomer  @relation(fields: [billingCustomerId], references: [id], onDelete: Cascade)
  payments        BillingPayment[]

  @@index([billingCustomerId])
  @@index([provider])
  @@index([externalSubscriptionId])
  @@index([status])
  @@map("billing_subscriptions")
}

// Histórico de cobranças — ESPELHO. Não é fonte de verdade de nada.
model BillingPayment {
  id                    String    @id @default(cuid())
  billingSubscriptionId String
  provider              String    // mercadopago | stripe
  externalPaymentId     String?   // id do pagamento no gateway
  amount                Float     @default(0)
  currency              String    @default("BRL")
  status                String    // approved | rejected | refunded | pending | cancelled
  method                String?   // credit_card | pix | boleto ...
  paidAt                DateTime?
  createdAt             DateTime  @default(now())

  subscription BillingSubscription @relation(fields: [billingSubscriptionId], references: [id], onDelete: Cascade)

  @@unique([provider, externalPaymentId])
  @@index([billingSubscriptionId])
  @@index([status])
  @@map("billing_payments")
}

// Eventos de webhook — idempotência + rastreabilidade. externalEventId único por provider.
model WebhookEvent {
  id              String    @id @default(cuid())
  provider        String    // mercadopago | stripe
  externalEventId String    // id único do evento/notificação no gateway
  resourceId      String?   // id do recurso referenciado (payment/subscription)
  type            String    // tipo do evento (payment, subscription_preapproval, ...)
  payload         Json?
  result          String?   // processed | ignored | error | duplicate
  processedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@unique([provider, externalEventId])
  @@index([provider, type])
  @@index([resourceId])
  @@map("webhook_events")
}

// Auditoria financeira ISOLADA (separada do ActivityLog operacional).
// event: CHECKOUT_CREATED | CHECKOUT_COMPLETED | PAYMENT_APPROVED | PAYMENT_REJECTED |
//        PAYMENT_REFUNDED | SUBSCRIPTION_CREATED | SUBSCRIPTION_UPDATED |
//        SUBSCRIPTION_CANCELLED | PLAN_UPGRADED | PLAN_DOWNGRADED |
//        PAST_DUE_ENTERED | PAST_DUE_EXITED | SUSPENDED | REACTIVATED
model BillingAuditLog {
  id          String   @id @default(cuid())
  companyId   String
  event       String
  description String
  fromPlan    String?
  toPlan      String?
  amount      Float?
  provider    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([event])
  @@index([createdAt])
  @@map("billing_audit_logs")
}
