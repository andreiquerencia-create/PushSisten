// ============================================================
// FASE 7 — Backup, Recovery & Continuidade Operacional
// Tabela ADITIVA: registra metadados de cada backup lógico por empresa.
// Não altera nenhuma tabela existente nem nenhuma regra de negócio.
// ============================================================
model BackupRecord {
  id               String    @id @default(cuid())
  companyId        String?   // nullable: registro do backup sobrevive à exclusão da empresa
  companyName      String
  type             String    @default("manual")   // manual | auto | pre_delete
  status           String    @default("pending")  // pending | running | completed | failed
  version          String
  cloudStoragePath String?   // caminho no S3 (armazenamento principal)
  fileSizeBytes    Int?
  recordCounts     Json?     // { model: count }
  totalRecords     Int       @default(0)
  durationMs       Int?
  appCheckpoint    String?   // commit/checkpoint da app no momento do backup
  schemaVersion    String?
  error            String?
  createdById      String?
  createdByName    String?
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  createdAt        DateTime  @default(now())

  @@index([companyId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("backup_records")
}

// FASE 7 — ETAPA 5: configuração (singleton) de backup automático + retenção.
// Aditivo: NÃO altera nenhum modelo existente. id fixo "global".
model BackupSchedule {
  id               String   @id @default("global")
  enabled          Boolean  @default(true)
  hourBrt          Int      @default(3)   // hora local BRT do disparo (0-23)
  retentionDaily   Int      @default(7)
  retentionWeekly  Int      @default(4)
  retentionMonthly Int      @default(12)
  scope            String   @default("active") // active = todas empresas ativas
  lastRunAt        DateTime?
  lastRunStatus    String?  // running | completed | failed
  lastRunSummary   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("backup_schedules")
}

