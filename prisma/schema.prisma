generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/push_sisten/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Company {
  id          String   @id @default(cuid())
  isProtected Boolean  @default(false)   // proteção contra exclusão em massa (empresas de produção/críticas)
  name        String
  cnpj        String?  @unique
  email       String?
  phone       String?
  whatsapp    String?
  instagram   String?
  logoUrl     String?
  address     String?
  city        String?
  state       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // SaaS fields
  plan                String   @default("trial")
  subscriptionStatus  String   @default("active")
  trialEndsAt         DateTime?
  trialDays           Int      @default(14)
  maxUsers            Int      @default(3)
  aiQuotaMonthly      Int      @default(50)
  aiCallsThisMonth    Int      @default(0)
  aiCallsResetAt      DateTime?
  lastAccessAt        DateTime?

  // Billing (P8.4) — Company guarda APENAS o estado de acesso vigente.
  // Tudo do gateway vive em BillingCustomer/BillingSubscription (desacoplado).
  // billingStatus: NONE | ACTIVE | PAST_DUE | SUSPENDED | CANCELED
  billingStatus       String    @default("NONE")
  // Fim do período de tolerância de inadimplência (PAST_DUE). Durante a tolerância a empresa continua usando.
  gracePeriodEndsAt   DateTime?

  // Price table minimum quantity validation behavior: block | warn | allow (padrão: allow — apenas referência)
  priceTableMinQtyBehavior String @default("allow")

  // WhatsApp default app: ask | whatsapp | business (padrão: ask — perguntar sempre)
  whatsappDefaultApp String @default("ask")

  // Numeração sequencial de vendas por empresa (último número emitido). Incrementado atomicamente na criação de venda/orçamento.
  lastSaleNumber     Int    @default(0)

  users              User[]
  categories         Category[]
  products           Product[]
  customers          Customer[]
  sales              Sale[]
  inventoryMovements InventoryMovement[]
  financialRecords   FinancialRecord[]
  financialCategories FinancialCategory[]
  suppliers          Supplier[]
  carriers           Carrier[]
  sellers            Seller[]
  accountsPayable    AccountPayable[]
  accountsReceivable AccountReceivable[]
  iaMemories         IAMemory[]
  iaConversations    IAConversation[]
  iaContexts         IAOperationalContext[]
  iaAlerts           IAAlert[]
  automations        Automation[]
  automationActions  AutomationAction[]
  whatsappConfig     WhatsAppConfig?
  cashAccounts       CashAccount[]
  cashMovements      CashMovement[]
  cashSessions       CashSession[]
  importLogs         ImportLog[]
  paymentMethods     PaymentMethod[]
  salePayments       SalePayment[]
  messageTemplates   MessageTemplate[]
  accountPlans       AccountPlan[]
  aiClassificationLogs AiClassificationLog[]
  activityLogs       ActivityLog[]
  priceTables        PriceTable[]
  stockEntries       StockEntry[]
  ledgerEntries      LedgerEntry[]
  customerCredits    CustomerCredit[]
  installments       Installment[]
  installmentPayments InstallmentPayment[]
  pushScoreSnapshots PushScoreSnapshot[]
  pushScoreConfigs   PushScoreConfig[]
  insights           Insight[]
  billingCustomer    BillingCustomer?
  billingAuditLogs   BillingAuditLog[]

  @@map("companies")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("vendedor")
  phone         String?
  isActive      Boolean   @default(true)
  isMaster      Boolean   @default(false)
  companyId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company?  @relation(fields: [companyId], references: [id])
  sales         Sale[]
  seller        Seller?

  @@index([companyId])
  @@map("users")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  companyId   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id])
  products    Product[]

  @@index([companyId])
  @@map("categories")
}

model Product {
  id              String   @id @default(cuid())
  name            String
  sku             String?
  barcode         String?
  description     String?
  costPrice       Float    @default(0)
  salePrice       Float    @default(0)
  margin          Float    @default(0)
  stockQuantity   Int      @default(0)
  minStock        Int      @default(0)
  imageUrl        String?
  cloudStoragePath String?
  isPublic        Boolean  @default(true)
  isActive        Boolean  @default(true)
  categoryId      String?
  supplierId      String?
  companyId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Cost engine fields
  avgCost           Float    @default(0)
  lastCost          Float    @default(0)
  replacementCost   Float    @default(0)

  category          Category?          @relation(fields: [categoryId], references: [id])
  supplier          Supplier?          @relation(fields: [supplierId], references: [id])
  company           Company            @relation(fields: [companyId], references: [id])
  saleItems         SaleItem[]
  inventoryMovements InventoryMovement[]
  variations        ProductVariation[]
  priceTables       PriceTable[]
  stockEntryItems   StockEntryItem[]
  costHistory       CostHistory[]

  @@unique([sku, companyId], name: "unique_sku_per_company")
  @@index([companyId])
  @@index([categoryId])
  @@index([supplierId])
  @@map("products")
}

model ProductVariation {
  id            String   @id @default(cuid())
  productId     String
  color         String?
  size          String?
  grade         String?
  sku           String?
  barcode       String?
  costPrice     Float    @default(0)
  salePrice     Float    @default(0)
  stockQuantity Int      @default(0)
  minStock      Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Cost engine fields
  avgCost         Float    @default(0)
  lastCost        Float    @default(0)
  replacementCost Float    @default(0)

  product            Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  saleItems          SaleItem[]
  inventoryMovements InventoryMovement[]
  stockEntryItems    StockEntryItem[]

  @@index([productId])
  @@index([barcode])
  @@index([sku])
  @@map("product_variations")
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phone         String?
  whatsapp      String?
  cpfCnpj       String?
  city          String?
  state         String?
  type          String   @default("varejo")
  tags          String[] @default([])
  totalPurchased Float   @default(0)
  avgTicket     Float    @default(0)
  lastPurchase  DateTime?
  purchaseCount Int      @default(0)
  companyId     String
  sellerId      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id])
  seller        Seller?  @relation(fields: [sellerId], references: [id])
  sales         Sale[]
  receivables   AccountReceivable[]
  credit        CustomerCredit?
  installments  Installment[]

  @@index([companyId])
  @@index([type])
  @@index([sellerId])
  @@map("customers")
}

model Sale {
  id              String     @id @default(cuid())
  saleNumber      Int        @default(autoincrement())
  companySaleNumber Int?     // Numeração sequencial por empresa (exibição). saleNumber permanece como referência técnica global.
  customerId      String?
  sellerId        String?
  companyId       String
  subtotal        Float      @default(0)
  discount        Float      @default(0)
  total           Float      @default(0)
  paymentMethod   String     @default("dinheiro")
  status          String     @default("concluida")
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Audit fields
  createdById     String?    // User ID who created/launched this sale
  createdByName   String?    // Name of user who created
  updatedById     String?    // User ID who last edited
  updatedByName   String?    // Name of user who last edited
  editHistory     String?    // JSON string tracking edit history

  customer        Customer?  @relation(fields: [customerId], references: [id])
  seller          User?      @relation(fields: [sellerId], references: [id])
  company         Company       @relation(fields: [companyId], references: [id])
  items           SaleItem[]
  payments        SalePayment[]
  installments    Installment[]

  @@unique([companyId, companySaleNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([sellerId])
  @@index([createdAt])
  @@map("sales")
}

model SaleItem {
  id              String  @id @default(cuid())
  saleId          String
  productId       String
  variationId     String?
  quantity        Int     @default(1)
  unitPrice       Float   @default(0)
  discount        Float   @default(0)
  total           Float   @default(0)
  // Price table tracking fields (nullable for backward compatibility)
  priceTableId    String?
  priceTableName  String?
  originalPrice   Float?
  appliedPrice    Float?
  priceDiscount   Float?

  sale        Sale              @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product           @relation(fields: [productId], references: [id])
  variation   ProductVariation? @relation(fields: [variationId], references: [id])
  priceTable  PriceTable?       @relation(fields: [priceTableId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@index([variationId])
  @@index([priceTableId])
  @@map("sale_items")
}

model InventoryMovement {
  id            String   @id @default(cuid())
  productId     String
  variationId   String?
  companyId     String
  type          String   // entrada, saida, ajuste_manual, inventario, venda, cancelamento, reserva, devolucao, entrada_mercadoria
  quantity      Int
  previousQty   Int      @default(0)
  newQty        Int      @default(0)
  reason        String?
  reference     String?
  stockEntryId  String?
  userId        String?
  userName      String?
  createdAt     DateTime @default(now())

  product       Product            @relation(fields: [productId], references: [id])
  variation     ProductVariation?  @relation(fields: [variationId], references: [id])
  company       Company            @relation(fields: [companyId], references: [id])
  stockEntry    StockEntry?        @relation(fields: [stockEntryId], references: [id])

  @@index([companyId])
  @@index([productId])
  @@index([variationId])
  @@index([createdAt])
  @@index([type])
  @@index([stockEntryId])
  @@map("inventory_movements")
}

model StockEntry {
  id              String    @id @default(cuid())
  entryNumber     Int       @default(autoincrement())
  companyId       String
  supplierId      String?
  status          String    @default("confirmada") // confirmada, cancelada
  subtotal        Float     @default(0)
  freight         Float     @default(0)
  otherExpenses   Float     @default(0)
  totalCost       Float     @default(0)
  paymentMethod   String    @default("a_vista") // a_vista, parcelado
  installments    Int       @default(1)
  notes           String?
  updateAvgCost   Boolean   @default(true)
  cancelReason    String?
  cancelledAt     DateTime?
  cancelledById   String?
  cancelledByName String?
  createdById     String?
  createdByName   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company         Company         @relation(fields: [companyId], references: [id])
  supplier        Supplier?       @relation(fields: [supplierId], references: [id])
  items           StockEntryItem[]
  movements       InventoryMovement[]
  accountsPayable AccountPayable[]

  @@index([companyId])
  @@index([supplierId])
  @@index([createdAt])
  @@index([status])
  @@map("stock_entries")
}

model StockEntryItem {
  id              String   @id @default(cuid())
  stockEntryId    String
  productId       String
  variationId     String?
  quantity        Int      @default(0)
  unitCost        Float    @default(0)
  totalCost       Float    @default(0)
  previousAvgCost Float    @default(0)
  newAvgCost      Float    @default(0)
  createdAt       DateTime @default(now())

  stockEntry      StockEntry        @relation(fields: [stockEntryId], references: [id], onDelete: Cascade)
  product         Product           @relation(fields: [productId], references: [id])
  variation       ProductVariation? @relation(fields: [variationId], references: [id])

  @@index([stockEntryId])
  @@index([productId])
  @@index([variationId])
  @@map("stock_entry_items")
}

model CostHistory {
  id              String   @id @default(cuid())
  productId       String
  variationId     String?
  companyId       String
  previousCost    Float    @default(0)
  newCost         Float    @default(0)
  costType        String   // avg_cost, last_cost, replacement_cost
  reason          String?  // entrada_mercadoria, ajuste_manual, importacao
  reference       String?
  userId          String?
  userName        String?
  createdAt       DateTime @default(now())

  product         Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([companyId])
  @@index([createdAt])
  @@map("cost_history")
}

model FinancialCategory {
  id          String   @id @default(cuid())
  name        String
  type        String
  companyId   String
  createdAt   DateTime @default(now())

  company     Company  @relation(fields: [companyId], references: [id])
  records     FinancialRecord[]

  @@index([companyId])
  @@map("financial_categories")
}

model FinancialRecord {
  id              String   @id @default(cuid())
  description     String
  amount          Float
  type            String
  paymentMethod   String?
  categoryId      String?
  accountPlanId   String?
  cashAccountId   String?  // Caixa vinculado (obrigatório para lançamentos manuais)
  cashMovementId  String?  // CashMovement correspondente (link 1:1)
  companyId       String
  reference       String?
  date            DateTime @default(now())
  createdAt       DateTime @default(now())

  category        FinancialCategory? @relation(fields: [categoryId], references: [id])
  accountPlan     AccountPlan?       @relation(fields: [accountPlanId], references: [id])
  company         Company            @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([type])
  @@index([date])
  @@index([accountPlanId])
  @@index([cashAccountId])
  @@index([cashMovementId])
  @@map("financial_records")
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  whatsapp    String?
  email       String?
  city        String?
  state       String?
  cnpj        String?
  notes       String?
  companyId   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id])
  products    Product[]
  accountsPayable AccountPayable[]
  stockEntries    StockEntry[]

  @@index([companyId])
  @@map("suppliers")
}

model Carrier {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  city        String?
  state       String?
  notes       String?
  companyId   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("carriers")
}

model Seller {
  id              String     @id @default(cuid())
  name            String
  phone           String?
  commissionRate  Float      @default(5)
  canEditPrice    Boolean    @default(false)
  isActive        Boolean    @default(true)
  companyId       String
  userId          String?    @unique
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  company         Company    @relation(fields: [companyId], references: [id])
  user            User?      @relation(fields: [userId], references: [id])
  customers       Customer[]

  @@index([companyId])
  @@map("sellers")
}

model AccountPayable {
  id              String    @id @default(cuid())
  description     String
  amount          Float
  dueDate         DateTime
  paidDate        DateTime?
  status          String    @default("pendente")
  supplierId      String?
  categoryId      String?
  stockEntryId    String?
  companyId       String
  notes           String?
  installmentNum  Int?
  totalInstallments Int?
  isRecurring     Boolean   @default(false)
  recurringPeriodicity String?
  recurringEndDate DateTime?
  parentRecurringId String?
  accountPlanId   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  supplier        Supplier?   @relation(fields: [supplierId], references: [id])
  stockEntry      StockEntry? @relation(fields: [stockEntryId], references: [id])
  company         Company     @relation(fields: [companyId], references: [id])
  accountPlan     AccountPlan? @relation("AccountPlanPayables", fields: [accountPlanId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([dueDate])
  @@index([stockEntryId])
  @@index([isRecurring])
  @@index([accountPlanId])
  @@map("accounts_payable")
}

model AccountReceivable {
  id              String    @id @default(cuid())
  description     String
  amount          Float
  dueDate         DateTime
  receivedDate    DateTime?
  status          String    @default("pendente")
  customerId      String?
  saleId          String?
  accountPlanId   String?
  companyId       String
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer        Customer? @relation(fields: [customerId], references: [id])
  accountPlan     AccountPlan? @relation(fields: [accountPlanId], references: [id])
  company         Company   @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([dueDate])
  @@index([customerId])
  @@index([accountPlanId])
  @@map("accounts_receivable")
}

model CashAccount {
  id              String    @id @default(cuid())
  name            String
  type            String    @default("dinheiro") // dinheiro, banco, pix, cartao
  initialBalance  Float     @default(0)
  currentBalance  Float     @default(0)
  isActive        Boolean   @default(true)
  notes           String?
  companyId       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company              Company   @relation(fields: [companyId], references: [id])
  paymentMethods       PaymentMethod[]
  movements            CashMovement[]
  sessions             CashSession[]
  installmentPayments  InstallmentPayment[]

  @@index([companyId])
  @@map("cash_accounts")
}

model CashMovement {
  id              String    @id @default(cuid())
  cashAccountId   String
  companyId       String
  type            String    // entrada, saida, transferencia_entrada, transferencia_saida
  amount          Float
  balanceBefore   Float     @default(0)
  balanceAfter    Float     @default(0)
  origin          String    // venda_pdv, ajuste_manual, transferencia, recebimento_cartao, pagamento_conta, entrada_financeira, saida_financeira, sangria, reforco
  description     String
  reference       String?   // e.g. Venda #152, Conta #45
  userId          String?
  userName        String?
  notes           String?
  linkedMovementId String?  // for transfers — links to the counterpart movement
  cashSessionId   String?
  createdAt       DateTime  @default(now())

  cashAccount     CashAccount  @relation(fields: [cashAccountId], references: [id])
  company         Company      @relation(fields: [companyId], references: [id])
  cashSession     CashSession? @relation(fields: [cashSessionId], references: [id])

  @@index([cashAccountId])
  @@index([companyId])
  @@index([createdAt])
  @@index([type])
  @@index([origin])
  @@index([cashSessionId])
  @@map("cash_movements")
}

model CashSession {
  id              String    @id @default(cuid())
  cashAccountId   String
  companyId       String
  status          String    @default("aberto") // aberto, fechado
  openingBalance  Float     @default(0)
  closingBalance  Float?
  expectedBalance Float?
  informedBalance Float?
  difference      Float?
  openedById      String?
  openedByName    String?
  closedById      String?
  closedByName    String?
  openedAt        DateTime  @default(now())
  closedAt        DateTime?
  closingNotes    String?

  // Breakdown at closing
  totalSales      Float?    @default(0)
  totalCash       Float?    @default(0)
  totalPix        Float?    @default(0)
  totalCard       Float?    @default(0)
  totalEntries    Float?    @default(0)
  totalExits      Float?    @default(0)
  totalSangrias   Float?    @default(0)
  totalReforcos   Float?    @default(0)

  cashAccount     CashAccount  @relation(fields: [cashAccountId], references: [id])
  company         Company      @relation(fields: [companyId], references: [id])
  movements       CashMovement[]

  @@index([cashAccountId])
  @@index([companyId])
  @@index([status])
  @@index([openedAt])
  @@map("cash_sessions")
}

model PaymentMethod {
  id                String    @id @default(cuid())
  name              String
  type              String    @default("dinheiro") // dinheiro, pix, cartao_credito, cartao_debito, boleto, transferencia, outro
  cashAccountId     String
  defaultDays       Int       @default(0)
  feePercent        Float     @default(0)
  feeFixed          Float     @default(0)
  businessDays      Boolean   @default(false) // true = dias uteis, false = dias corridos
  isActive          Boolean   @default(true)
  companyId         String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  cashAccount       CashAccount @relation(fields: [cashAccountId], references: [id])
  company           Company     @relation(fields: [companyId], references: [id])
  salePayments      SalePayment[]

  @@index([companyId])
  @@index([cashAccountId])
  @@map("payment_methods")
}

model SalePayment {
  id                String    @id @default(cuid())
  saleId            String
  paymentMethodId   String
  amount            Float
  feePercent        Float     @default(0)
  feeAmount         Float     @default(0)
  netAmount         Float     @default(0)
  expectedDate      DateTime
  received          Boolean   @default(false)
  receivedDate      DateTime?
  cashAccountId     String
  companyId         String
  createdAt         DateTime  @default(now())

  sale              Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  paymentMethod     PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  company           Company       @relation(fields: [companyId], references: [id])

  @@index([saleId])
  @@index([paymentMethodId])
  @@index([cashAccountId])
  @@index([companyId])
  @@index([expectedDate])
  @@map("sale_payments")
}

model IAMemory {
  id          String    @id @default(cuid())
  companyId   String
  type        String    @default("long")
  category    String    @default("general")
  content     String
  metadata    String?
  importance  Int       @default(5)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company   @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([type])
  @@index([category])
  @@map("ia_memories")
}

model IAConversation {
  id          String   @id @default(cuid())
  companyId   String
  userId      String?
  title       String?
  messages    String
  summary     String?
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([createdAt])
  @@map("ia_conversations")
}

model IAOperationalContext {
  id          String   @id @default(cuid())
  companyId   String
  period      String   @default("daily")
  summary     String
  metrics     String
  trends      String?
  createdAt   DateTime @default(now())

  company     Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([period])
  @@index([createdAt])
  @@map("ia_operational_contexts")
}

model IAAlert {
  id          String    @id @default(cuid())
  companyId   String
  type        String    @default("observation")
  category    String    @default("general")
  title       String
  description String
  suggestion  String?
  impact      String?
  isResolved  Boolean   @default(false)
  resolvedAt  DateTime?
  resolvedBy  String?
  metadata    String?
  createdAt   DateTime  @default(now())

  company     Company   @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([type])
  @@index([isResolved])
  @@index([createdAt])
  @@map("ia_alerts")
}

model Automation {
  id          String    @id @default(cuid())
  companyId   String
  name        String
  description String?
